{
  "name": "life-os",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:api": "uvicorn app.main:app --reload --app-dir apps/api --reload-dir apps/api/app --reload-dir apps/api/tests --reload-exclude '.venv/*'",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "supabase": "^2.83.0"
  }
}
