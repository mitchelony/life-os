APP_NAME=Life OS API
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional legacy single-origin fallback for LAN testing:
# ALLOWED_ORIGIN=http://192.168.1.162:3000
DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=postgresql+psycopg://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
DEFAULT_CURRENCY=USD
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_AUTH_USER_PATH=/auth/v1/user
OWNER_ID=11111111-1111-1111-1111-111111111111
DEV_OWNER_TOKEN=replace-with-a-random-unused-dev-token
AUTH_STRATEGY=supabase
ALLOW_DEV_LOGIN=false
