# Shared
ENVIRONMENT=development

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_DB_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_AUTH_USER_PATH=/auth/v1/user

# API
API_HOST=0.0.0.0
API_PORT=8000
APP_SECRET_KEY=replace-with-a-long-random-string
ALLOWED_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
AUTH_STRATEGY=supabase
ALLOW_DEV_LOGIN=false
# Optional local-only fallback. Keep disabled unless you explicitly need it.
DEV_OWNER_TOKEN=replace-with-a-random-dev-token

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
