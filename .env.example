# Shared
ENVIRONMENT=development

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_DB_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres

# API
API_HOST=0.0.0.0
API_PORT=8000
APP_SECRET_KEY=replace-with-a-long-random-string
ALLOW_DEV_LOGIN=true
OWNER_EMAIL=you@example.com
ALLOWED_ORIGIN=http://localhost:3000
DATABASE_URL=sqlite:///./life_os.db
DEV_OWNER_TOKEN=replace-with-a-random-dev-token
AUTH_STRATEGY=dev-token

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
