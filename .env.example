# Shared
ENVIRONMENT=development
APP_NAME=Life OS API
DEFAULT_CURRENCY=USD

# Hosted Supabase
# Use the same hosted project for both API and web auth.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_AUTH_USER_PATH=/auth/v1/user

# Database
# If you use the Supabase pooler, the username must be postgres.<project_ref>.
# Example:
# postgresql+psycopg://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=postgresql+psycopg://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
AUTH_STRATEGY=supabase
ALLOW_DEV_LOGIN=false
# Local-only fallback. Keep disabled unless you explicitly need it for debugging.
DEV_OWNER_TOKEN=replace-with-a-random-unused-dev-token

# Roadmap copilot planner
# Leave as `heuristic` to avoid model calls.
AI_PLANNER_PROVIDER=heuristic
# For OpenAI direct, switch provider to `openai`, set a model, and add your key.
# Example:
# AI_PLANNER_PROVIDER=openai
# AI_PLANNER_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
AI_PLANNER_MODEL=
AI_PLANNER_BASE_URL=https://api.openai.com
AI_PLANNER_API_KEY=
OPENAI_API_KEY=
AI_PLANNER_TIMEOUT_SECONDS=25
AI_PLANNER_MAX_OUTPUT_TOKENS=4000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
NEXT_PUBLIC_ONBOARDING_KEY=life-os-onboarded
